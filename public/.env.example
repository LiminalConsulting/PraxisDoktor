# Public site → practice server bridge.
# These are baked into the static build at deploy time.

# Base URL of the practice's tunneled API (Cloudflare Tunnel target).
# Local dev: http://127.0.0.1:8080
# Production: https://app.uro-karlsruhe.de
VITE_PRACTICE_API=http://127.0.0.1:8080

# Shared key the public site sends as X-Public-Key. Friction reducer, not a secret.
# Read from the practice server's var/public_api_key.txt after first start, or set
# in the practice's installer's silent flags.
VITE_PUBLIC_API_KEY=dev-placeholder-change-me
