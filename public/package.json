		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"vite": "^8.0.7",
		"wrangler": "^4.84.1"
	},
	"dependencies": {
		"@tailwindcss/vite": "^4.2.4",
		"clsx": "^2.1.1",
		"lucide-svelte": "^1.0.1",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.2.4"
	}
}
